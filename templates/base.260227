<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>{{ page_title or WEBSITE_NAME }}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css">
<!--  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">-->
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
{% block styles %}
<style>
/* ---------- BASE LAYOUT ---------- */

body {
  background-color: #f5f6f8;
  font-size: 1rem;
  line-height: 1.5;
}

.my-icon {
  color: #00c853;
}

/* Sidebar */
.sidebar {
  background-color: #343a40;
  color: #fff;
  padding-top: 1rem;
  min-height: 100vh;
}

.sidebar .sidebar-heading {
  display: flex;
  align-items: center;
  gap: 8px;
  justify-content: flex-start;  /* ← key line */
}

.sidebar .nav-link {
  color: #ccc;
  font-weight: 500;
  padding: 10px 16px;
  font-size: 1rem;
}

.sidebar .nav-link:hover,
.sidebar .nav-link.active {
  color: #fff;
  background-color: #495057;
  border-radius: 6px;
}

.sidebar .nav .nav {
  margin-left: 1rem;
}

.sidebar-user {
  background-color: rgba(255,255,255,0.03);
}

.sidebar-user .fw-semibold {
  color: #fff;
}

.sidebar-user .small {
  color: #adb5bd;
}

/* Page header */
.page-header {
  background-color: #343a40;
  color: #fff;
  padding: 1rem 1.5rem;
  margin-bottom: 1rem;
  border-radius: 8px;
}

/* ---------- MOBILE OPTIMISATION ---------- */
@media (max-width: 768px) {

  html, body {
    font-size: 1.05rem;
  }

  .sidebar {
    position: fixed;
    top: 0;
    left: -80vw;
    width: 75vw;
    height: 100vh;
    z-index: 1050;
    overflow-y: auto;
    font-size: 1.1rem;
    padding-top: 1.25rem;
    transition: left 0.25s ease;
  }

  .sidebar.show {
    left: 0;
  }

  .sidebar .nav-link {
    padding: 14px 20px;
    font-size: 1.1rem;
  }

  main {
    padding: 0.5rem;
  }

  body.sidebar-open {
    overflow: hidden;
  }

  .page-header {
    padding: 0.75rem 1rem;
    font-size: 1.1rem;
  }
}

/* ---------- LOGIN CARD ---------- */
.login-card {
  width: 100%;
  max-width: 380px;
  border-radius: 12px;
  margin: 0 auto;
}

.login-card .form-control {
  border-radius: 8px;
  padding: 10px 12px;
}

.login-card .btn {
  border-radius: 8px;
  padding: 10px;
}

footer.footer {
  padding: 1rem;
  font-size: 0.9rem;
}
</style>
{% endblock %}
</head>
<body>

<!-- Mobile navbar with hamburger -->
<nav class="navbar navbar-dark bg-dark d-md-none">
  <div class="container-fluid">
    <button class="btn btn-outline-light" type="button" onclick="toggleSidebar()">
      <i class="bi bi-list"></i> Menu
    </button>
    <span class="navbar-brand mb-0 h1">{{ WEBSITE_NAME }}</span>
  </div>
</nav>

<div class="container-fluid">
  <div class="row">

<!-- base.html sidebar -->
<nav class="sidebar">
  <ul class="nav flex-column">

    {% set sidebar_items = get_sidebar_items() %}

    {% for bp, views in sidebar_items.items() %}
      {% for view in views %}
        <li class="nav-item">
          <a class="nav-link" href="{{ url_for(bp ~ '.' ~ view) }}">
            {{ view.replace('_',' ')|capitalize }}
          </a>
        </li>
      {% endfor %}
    {% endfor %}

    <!-- Login/Logout links -->
    {% if current_user.is_authenticated %}
      <li class="nav-item mt-3">
        <a class="nav-link text-danger" href="{{ url_for('logout') }}">
          Logout {{ current_user.username }}
        </a>
      </li>
    {% else %}
      <li class="nav-item">
        <a class="nav-link" href="{{ url_for('login') }}">
          Login
        </a>
      </li>
    {% endif %}

  </ul>
</nav>

    <!-- Sidebar -->
    <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse">
      <div class="position-sticky">

        <h5 class="px-3 mb-3 text-white">
          <a href="{{ url_for('index') }}" class="text-decoration-none text-white h5 d-block">
            <i class="bi bi-graph-up"></i> {{ WEBSITE_NAME }}
          </a>
        </h5>

        <ul class="nav flex-column">

          <!-- Admin  submenu -->
          <li class="nav-item">
            <a class="nav-link text-white d-flex justify-content-between align-items-center sidebar-toggle"
               data-bs-toggle="collapse"
               href="#adminMenu"
               role="button"
               aria-expanded="{{ 'true' if request.path.startswith('/admin') else 'false' }}"
               aria-controls="adminMenu">
              <i class="bi bi-tools my-icon sidebar-heading"></i> Admin
              <i class="bi bi-chevron-down"></i>
            </a>
            <div class="collapse {% if request.path.startswith('/admin') %}show{% endif %}" id="adminMenu">
              <ul class="nav flex-column ms-3">
                <li class="nav-item">
                  <a class="nav-link sidebar-link {% if request.path == '/admin/' %}{% endif %}"
                     href="{{ url_for('admin.dashboard') }}">
                    <i class="bi bi-bar-chart"></i> Dashboard
                  </a>
                </li>
              </ul>
            </div>
            <div class="collapse {% if request.path.startswith('/admin') %}show{% endif %}" id="adminMenu">
              <ul class="nav flex-column ms-3">
                <li class="nav-item">
                  <a class="nav-link sidebar-link {% if request.path == '/admin/' %}{% endif %}"
                     href="{{ url_for('admin.admin_logs') }}">
                    <i class="bi bi-card-text"></i> Log
                  </a>
                </li>
              </ul>
            </div>
          </li>


          <!-- Personal submenu -->
          <li class="nav-item">
            <a class="nav-link text-white d-flex justify-content-between align-items-center sidebar-toggle"
               data-bs-toggle="collapse"
               href="#personalMenu"
               role="button"
               aria-expanded="{{ 'true' if request.path.startswith('/personal') else 'false' }}"
               aria-controls="personalMenu">
              <i class="bi bi-person-circle my-icon sidebar-heading"></i> Personal
              <i class="bi bi-chevron-down"></i>
            </a>
            <div class="collapse {% if request.path.startswith('/personal') %}show{% endif %}" id="personalMenu">
              <ul class="nav flex-column ms-3">
                <li class="nav-item">
                  <a class="nav-link sidebar-link {% if request.path == '/personal/' %}{% endif %}"
                     href="{{ url_for('personal.countdown') }}">
                    <i class="bi bi-1-circle"></i> Countdown
                  </a>
                </li>
              </ul>
            </div>
            <div class="collapse {% if request.path.startswith('/personal') %}show{% endif %}" id="personalMenu">
              <ul class="nav flex-column ms-3">
                <li class="nav-item">
                  <a class="nav-link sidebar-link {% if request.path == '/personal/' %}{% endif %}"
                     href="{{ url_for('personal.alcohol') }}">
                    <i class="bi bi-cup-straw"></i> Alcohol
                  </a>
                </li>
              </ul>
            </div>
           <div class="collapse {% if request.path.startswith('/personal') %}show{% endif %}" id="personalMenu">
              <ul class="nav flex-column ms-3">
                <li class="nav-item">
                  <a class="nav-link sidebar-link {% if request.path == '/personal/' %}{% endif %}"
                     href="{{ url_for('personal.finance') }}">
                    <i class="bi bi-currency-pound"></i> Finance
                  </a>
                </li>
              </ul>
            </div>
          </li>

          <!-- Parkrun submenu -->
          <li class="nav-item">
            <a class="nav-link text-white d-flex justify-content-between align-items-center sidebar-toggle"
               data-bs-toggle="collapse"
               href="#parkrunMenu"
               role="button"
               aria-expanded="{{ 'true' if request.path.startswith('/parkrun') else 'false' }}"
               aria-controls="parkrunMenu">
              <i class="bi bi-person-walking my-icon"></i> Parkrun
              <i class="bi bi-chevron-down"></i>
            </a>
            <div class="collapse {% if request.path.startswith('/parkrun') %}show{% endif %}" id="parkrunMenu">
              <ul class="nav flex-column ms-3">
                <li class="nav-item">
                  <a class="nav-link sidebar-link {% if request.path == '/parkrun/' %}active{% endif %}"
                     href="{{ url_for('parkrun.dashboard') }}">
                    <i class="bi bi-bar-chart"></i> Dashboard
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link sidebar-link {% if request.path.startswith('/parkrun/difficulty') %}active{% endif %}"
                     href="{{ url_for('parkrun.difficulty') }}">
                    <i class="bi bi-flag"></i> Course Difficulty
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link sidebar-link {% if request.path.startswith('/parkrun/mostevents') %}active{% endif %}"
                     href="{{ url_for('parkrun.mostevents') }}">
                    <i class="bi bi-trophy"></i> Most Events
                  </a>
                </li>
              </ul>
            </div>
          </li>

          <!-- Analytics submenu -->
          <li class="nav-item mt-2">
            <a class="nav-link text-white d-flex justify-content-between align-items-center sidebar-toggle"
               data-bs-toggle="collapse"
               href="#txMenu"
               role="button"
               aria-expanded="{{ 'true' if request.path.startswith('/tx') else 'false' }}"
               aria-controls="txMenu">
              <i class="bi bi-currency-pound my-icon"></i> Analytics
              <i class="bi bi-chevron-down"></i>
            </a>
            <div class="collapse {% if request.path.startswith('/tx') %}show{% endif %}" id="txMenu">
              <ul class="nav flex-column ms-3">
                <li class="nav-item">
                  <a class="nav-link sidebar-link" href="{{ url_for('tx.dashboard') }}">
                    <i class="bi bi-bar-chart"></i> Dashboard
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link sidebar-link" href="{{ url_for('tx.dashboard') }}">
                    <i class="bi bi-graph-up"></i> Transactions
                  </a>
                </li>
              </ul>
            </div>
          </li>

          <hr class="bg-secondary">

<!--
	  {% if current_user.is_authenticated %}
  	  <div class="sidebar-user border-top p-3">
            <a href="{{ url_for('logout') }}" class="small">Sign out {{ current_user.username }}</a>
 	 </div>
         {% endif %}
-->
          <!-- Login / Logout -->
          {% if current_user.is_authenticated %}
          <li class="nav-item">
            <a class="nav-link text-danger" href="{{ url_for('logout') }}">
              <i class="bi bi-box-arrow-right"></i> Logout {{ current_user.username }}
            </a>
          </li>
          {% else %}
          <li class="nav-item">
            <a class="nav-link" href="{{ url_for('login') }}">
              <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
          </li>
          {% endif %}

        </ul>

        <div class="px-3 mt-4 text-light small opacity-75">
          Version {{ WEBSITE_VERSION }}
       </div>

      </div>
    </nav>

    <!-- Main content -->
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 pt-3">

      <!-- Page title banner -->
      <div class="page-header mb-3">
        <h4 class="mb-0">{{ page_title or "Dashboardx" }}</h4>
      </div>

      {% block content %}{% endblock %}

    </main>
  </div>
</div>

<!-- Footer -->
<footer class="footer mt-5 mb-3">
  <hr>
  <div class="d-flex justify-content-between">
    <span>{{ WEBSITE_NAME }}</span>
    <span>v{{ WEBSITE_VERSION }} • Red</span>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"></script>

<script>
function toggleSidebar() {
  const sidebar = document.querySelector(".sidebar");
  sidebar.classList.toggle("show");
  document.body.classList.toggle("sidebar-open");
}

document.querySelectorAll(".sidebar .nav-link").forEach(link => {
  link.addEventListener("click", function (e) {

    // If this is a blueprint heading → expand only, do NOT close
    if (this.classList.contains("sidebar-toggle")) {
      e.preventDefault();   // stops jump-to-anchor behaviour
      return;
    }

    // If this is a real navigation link → close sidebar
    if (this.classList.contains("sidebar-link")) {
      document.querySelector(".sidebar").classList.remove("show");
      document.body.classList.remove("sidebar-open");
    }
  });
});
</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
