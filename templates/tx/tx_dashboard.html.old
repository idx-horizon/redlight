{% extends "base.html" %}

{% block content %}

<div class="container mt-4">

    <h2 class="mb-4">Dashboard</h2>

    <!-- Summary Cards -->
    <div class="row">
        {% for row in supplier_summary %}
        <div class="col-md-6 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">{{ row.supplier }}</h5>
                    <h3>£{{ "{:,.0f}".format(row.amount) }}</h3>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5 class="card-title">Monthly Spend</h5>

            <div class="mb-3">
                <label for="supplierFilter" class="form-label">Select:</label>
                <select id="supplierFilter" class="form-select">
                    <option value="all" selected>All Suppliers</option>
                    {% for ds in chart_datasets %}
                    <option value="{{ ds.label }}">{{ ds.label }}</option>
                    {% endfor %}
                </select>
            </div>

            <canvas id="monthlySpendChart"></canvas>

            {% if not chart_labels %}
            <p class="text-muted mt-3">No monthly data available</p>
            {% endif %}
        </div>
    </div>

    <!-- Top Expense Areas -->
    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5 class="card-title">Top Expense Areas</h5>

            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Expense Area</th>
                        <th class="text-end">Total Spend</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in top_expense_areas %}
                    <tr>
                        <td>{{ row.expense_area }}</td>
                        <td class="text-end">£{{ "{:,.0f}".format(row.amount) }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>

            {% if not top_expense_areas %}
            <p class="text-muted">No expense area data available</p>
            {% endif %}
        </div>
    </div>

    <p class="text-muted mt-3">
        Last updated: {{ last_updated }}
    </p>

</div>


<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
const labels = {{ chart_labels | tojson }};
const fullDatasets = {{ chart_datasets | tojson }};
const supplierColors = {{ supplier_colors | tojson }};

const ctx = document.getElementById("monthlySpendChart").getContext("2d");

// Initial chart with all suppliers
let monthlyChart = new Chart(ctx, {
    type: "bar",
    data: {
        labels: labels,
        datasets: fullDatasets.map(ds => ({
            label: ds.label,
            data: ds.data,
            backgroundColor: supplierColors[ds.label] || 'rgba(100,100,100,0.7)'
        }))
    },
    options: {
        responsive: true,
        interaction: { mode: "index", intersect: false },
        scales: {
            y: { beginAtZero: true }
        }
    }
});

// Handle supplier filter change
document.getElementById("supplierFilter").addEventListener("change", function() {
    const selected = this.value;
    let filteredDatasets;

    if (selected === "all") {
        filteredDatasets = fullDatasets;
    } else {
        filteredDatasets = fullDatasets.filter(ds => ds.label === selected);
    }

    monthlyChart.data.datasets = filteredDatasets.map(ds => ({
        label: ds.label,
        data: ds.data,
        backgroundColor: supplierColors[ds.label] || 'rgba(100,100,100,0.7)'
    }));

    monthlyChart.update();
});
</script>
{% endblock %}
