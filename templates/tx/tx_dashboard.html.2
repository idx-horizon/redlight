{% extends "base.html" %}

{% block content %}
<div class="container-fluid p-0">

    <!-- Supplier Filter -->
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex align-items-center flex-wrap">
            <h5 class="card-title me-3 mb-0">Filter by Supplier:</h5>
            <select id="supplierFilter" class="form-select w-auto">
                {% for supplier in suppliers %}
                    <option value="{{ supplier }}">{{ supplier }}</option>
                {% endfor %}
            </select>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3">
        {% for supplier in suppliers %}
        <div class="col-md-3">
            <div class="card supplier-total-card shadow-sm" data-supplier="{{ supplier }}">
                <div class="card-body text-center">
                    <h6>Total {{ supplier }}</h6>
                    <div class="card-value">£0</div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <!-- Monthly Spend Chart -->
    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5 class="card-title">Monthly Spend</h5>
            <canvas id="monthlySpendChart"></canvas>
        </div>
    </div>

    <!-- Monthly Spend Table -->
    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5 class="card-title">Monthly Spend Table</h5>
            <table class="table table-sm" id="monthlySpendTable">
                <thead>
                    <tr>
                        <th>Month</th>
                        <th>Supplier</th>
                        <th class="text-end">Total Spend</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
/* ===== DATA FROM FLASK ===== */
const suppliers = {{ suppliers | tojson }};
const chartLabels = {{ chart_labels | tojson }};
const chartDatasets = {{ chart_datasets | tojson }};
const supplierColors = {{ supplier_colors | tojson }};
const supplierSummary = {{ supplier_summary | tojson }};
const monthlyTable = {{ monthly_table | tojson }};

/* ===== STATE ===== */
let currentSupplier = suppliers[0];

/* ===== UTIL ===== */
function formatCurrency(v) {
    return "£" + Math.round(v).toLocaleString();
}

/* ===== SUPPLIER SELECT ===== */
const supplierSelect = document.getElementById("supplierSelect");
supplierSelect.value = currentSupplier;

supplierSelect.addEventListener("change", e => {
    currentSupplier = e.target.value;
    updateSummaryCard();
    updateChart();
    updateTable();
});

/* ===== SUMMARY CARD ===== */
function updateSummaryCard() {

    const s = supplierSummary[currentSupplier];

    if (!s) {
        document.getElementById("cardTitle").textContent = currentSupplier;
        document.getElementById("cardTotal").textContent = "£0";
        document.getElementById("cardCount").textContent = "0";
        document.getElementById("cardDates").textContent = "—";
        return;
    }

    document.getElementById("cardTitle").textContent = currentSupplier;
    document.getElementById("cardTotal").textContent = formatCurrency(s.total_amount);
    document.getElementById("cardCount").textContent = s.transaction_count.toLocaleString();
    document.getElementById("cardDates").textContent = s.min_date + " → " + s.max_date;
}

/* ===== CHART ===== */
const chartCanvas = document.getElementById("monthlySpendChart");
let monthlyChart = null;

function updateChart() {

    const dataset = chartDatasets.find(d => d.label === currentSupplier);

    if (!dataset) return;

    if (monthlyChart) {
        monthlyChart.destroy();
    }

    monthlyChart = new Chart(chartCanvas, {
        type: "bar",
        data: {
            labels: chartLabels,
            datasets: [{
                label: dataset.label,
                data: dataset.data,
                backgroundColor: supplierColors[currentSupplier]
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    ticks: {
                        callback: v => "£" + v.toLocaleString()
                    }
                }
            }
        }
    });
}

/* ===== TABLE ===== */
function updateTable() {

    const rows = monthlyTable.filter(
        r => r.supplier === currentSupplier
    );

    const tbody = document.getElementById("monthlyTableBody");
    tbody.innerHTML = "";

    rows.forEach(r => {
        const tr = document.createElement("tr");

        tr.innerHTML = `
            <td>${r.month}</td>
            <td>${formatCurrency(r.monthly_total)}</td>
        `;

        tbody.appendChild(tr);
    });
}

/* ===== INIT ===== */
updateSummaryCard();
updateChart();
updateTable();

console.log("TX dashboard ready:", currentSupplier);
</script>
{% endblock %}
